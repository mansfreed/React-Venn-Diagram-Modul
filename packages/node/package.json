{
  "name": "venn-diagram-lab",
  "version": "0.0.0",
  "description": "Headless Venn diagram analysis & rendering for Node — companion to the Venn Diagram Lab web tool.",
  "type": "module",
  "license": "MIT",
  "bin": { "vdl": "./dist/cli.js" },
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.cjs" }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "assets"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "dependencies": {
    "@venn-diagram-lab/core": "*",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
